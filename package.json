{
  "name": "svelte-boilerplate",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "prepare": "svelte-kit sync",
    "start": "vite dev",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "svelte-check --tsconfig ./tsconfig.json",
    "i18n:extract": "svelte-i18n extract 'src/**/*.svelte'",
    "msw": "bunx msw init"
  },
  "devDependencies": {
    "svelte-adapter-bun": "^1.0.1",
    "@sveltejs/kit": "^2.49.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "4.0.18",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "svelte": "^5.46.4",
    "svelte-check": "^4.3.5",
    "svelte-i18n": "^4.0.1",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  },
  "resolutions": {
    "cookie": "^1.0.2",
    "esbuild": "^0.25.0"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}